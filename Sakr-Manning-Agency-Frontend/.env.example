# ============================================================
# Sakr Maritime – Environment Variables
# Copy this file to .env and fill in the values.
# Never commit your real .env file to version control.
# ============================================================

# ----- API Configuration -----
# The active backend base URL used by all API calls.
# Override this in GitHub Secrets / your deployment env.
VITE_API_BASE_URL=https://backend.sakrshipping.com/api/

# Previous backend URL (kept for reference only – not used by the app)
# VITE_API_PREV_BASE_URL=https://api.backend.hs.vc/api/

# Optional: request timeout in milliseconds (default: 30000)
# VITE_API_TIMEOUT=30000

# ----- Google OAuth -----
# Required only if GOOGLE_AUTH feature flag is enabled in config.js
# VITE_GOOGLE_CLIENT_ID=your-google-client-id-here